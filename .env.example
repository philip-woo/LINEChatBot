# --- Postgres ---
DATABASE_URL=postgresql://localhost:5432/factory

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Dev only: set to 1 to skip LINE signature verification (NEVER in prod)
SKIP_LINE_SIGNATURE=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
# Verify current model strings at https://docs.claude.com/en/api/overview
ANTHROPIC_MODEL=claude-opus-4-8

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Embeddings (local, multilingual, no API key needed) ---
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384

# macOS Python SSL fix (point at certifi bundle); set by run script if empty
SSL_CERT_FILE=
